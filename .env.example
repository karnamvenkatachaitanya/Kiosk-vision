# ============================================================
# Kiosk Vision – Environment Configuration
# Copy this file to .env and adjust values for your deployment
# ============================================================

# --- General ---
PROJECT_NAME=kiosk-vision
ENVIRONMENT=production
LOG_LEVEL=info
SECRET_KEY=change-me-to-a-random-64-char-string

# --- Network ---
SERVER_IP=192.168.1.10
WIFI_SSID=ShopKiosk
DOMAIN=kiosk.local

# --- MongoDB ---
MONGO_URI=mongodb://mongodb:27017
MONGO_DB_AUTH=kiosk_auth
MONGO_DB_ORDERS=kiosk_orders
MONGO_DB_INVENTORY=kiosk_inventory
MONGO_DB_PAYMENT=kiosk_payment
MONGO_DB_CRM=kiosk_crm

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- MinIO (Object Storage) ---
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=kiosk-admin
MINIO_SECRET_KEY=change-me-minio-secret
MINIO_BUCKET=kiosk-assets

# --- Ollama (Local LLM) ---
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=mistral:7b-instruct-v0.3-q4_K_M

# --- AI Models ---
WHISPER_MODEL=small
WHISPER_DEVICE=cpu
PIPER_VOICE=en_US-lessac-medium
TTS_ENABLED=true

# --- JWT Auth ---
JWT_SECRET=change-me-jwt-secret
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=30

# --- UPI Payment ---
UPI_MERCHANT_ID=merchant@upi
UPI_MERCHANT_NAME=ShopName
UPI_CURRENCY=INR

# --- Service Ports (internal) ---
AUTH_SERVICE_PORT=8000
ORDER_SERVICE_PORT=8000
INVENTORY_SERVICE_PORT=8000
AI_SERVICE_PORT=8000
PAYMENT_SERVICE_PORT=8000
CRM_SERVICE_PORT=8000
